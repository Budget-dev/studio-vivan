rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      // Universal override for the master admin email
      return isSignedIn() && request.auth.token.email == 'vivanfarmsnatural@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Access ---
    // Absolute power for the master admin across ALL collections
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // --- Public Collection Rules ---
    // Essential for the storefront to load for visitors

    match /categories/{categoryId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
      match /variants/{variantId} {
        allow read: if true;
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // --- User and Order Rules ---

    match /userProfiles/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && request.query.limit <= 100;
    }

    match /adminRoles/{uid} {
      allow get: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'vivanfarmsnatural@gmail.com';
    }
  }
}