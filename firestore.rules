rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      // Master admin is the only account with universal permissions
      return isSignedIn() && request.auth.token.email == 'vivanfarmsnatural@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Access ---
    // This grants vivanfarmsnatural@gmail.com absolute permission over EVERYTHING
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // --- Public Collection Rules ---
    // These allow the website to load banners and products for logged-out visitors

    match /banners/{bannerId} {
      allow get, list: if true;
    }

    match /categories/{categoryId} {
      allow get, list: if true;
    }

    match /products/{productId} {
      allow get, list: if true;
      match /variants/{variantId} {
        allow get, list: if true;
      }
    }

    // --- User and Order Rules ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list: if false; // Only admin can list (covered by recursive rule)
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && request.query.limit <= 100; // Customer track order
    }

    match /adminRoles/{uid} {
      allow get: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'vivanfarmsnatural@gmail.com';
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}